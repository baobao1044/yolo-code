# Sample configuration for yolo-code
# Copy this file to .env and fill in real values
# (yolo-code auto-loads .env from the current directory on startup; any
#  variable already set in your shell or via a CLI flag takes precedence.)

# ── LLM Provider ──────────────────────────────────────────────
# API key (required). YOLO_API_KEY is canonical; OPENAI_API_KEY is read as a
# fallback only if YOLO_API_KEY is unset.
YOLO_API_KEY=sk-...
# (fallback) OPENAI_API_KEY=sk-...

# Base URL of the OpenAI-compatible API
# Default: https://api.openai.com/v1
YOLO_BASE_URL=https://api.openai.com/v1

# Model name (default: gpt-4o)
YOLO_MODEL=gpt-4o

# ── Logging ──────────────────────────────────────────────────
# Structured log file path (leave empty to disable file logging)
YOLO_LOG=

# ── Auto-approve (headless mode) ─────────────────────────────
# When true, medium-risk tools (e.g. bash) run without approval
# YOLO_AUTO_APPROVE_MEDIUM=true

# When true, high-risk tools (e.g. edit_file) run without approval
# YOLO_AUTO_APPROVE_HIGH=true

# ── Sandbox ──────────────────────────────────────────────────
# Repo root (default = current directory)
# YOLO_REPO_ROOT=.
