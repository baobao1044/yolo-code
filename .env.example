# Sample configuration for yolo-code
# Copy this file to .env and fill in real values

# ── LLM Provider ──────────────────────────────────────────────
# API key (required)
OPENAI_API_KEY=sk-...

# Base URL of the OpenAI-compatible API
# Default: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Model name
OPENAI_MODEL=gpt-4

# ── Logging ──────────────────────────────────────────────────
# Structured log file path (leave empty to disable file logging)
YOLO_LOG=

# ── Auto-approve (headless mode) ─────────────────────────────
# When true, medium-risk tools (e.g. bash) run without approval
# YOLO_AUTO_APPROVE_MEDIUM=true

# When true, high-risk tools (e.g. edit_file) run without approval
# YOLO_AUTO_APPROVE_HIGH=true

# ── Sandbox ──────────────────────────────────────────────────
# Repo root (default = current directory)
# YOLO_REPO_ROOT=.
