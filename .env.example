# Cấu hình mẫu cho yolo-code
# Copy file này thành .env và điền giá trị thực

# ── LLM Provider ──────────────────────────────────────────────
# API key (bắt buộc)
OPENAI_API_KEY=sk-...

# Base URL của OpenAI-compatible API
# Mặc định: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Tên model
OPENAI_MODEL=gpt-4

# ── WandB / Kimi K2.7 ────────────────────────────────────────
# Bỏ comment để dùng Kimi K2.7 qua WandB inference
# OPENAI_API_KEY=wandb_v1_...
# OPENAI_BASE_URL=https://api.inference.wandb.ai/v1
# OPENAI_MODEL=moonshotai/Kimi-K2.7-Code

# ── Logging ──────────────────────────────────────────────────
# Đường dẫn file log cấu trúc (bỏ trống = không log ra file)
YOLO_LOG=

# ── Auto-approve (headless mode) ─────────────────────────────
# Khi true, medium-risk tools (như bash) tự chạy mà không cần phê duyệt
# YOLO_AUTO_APPROVE_MEDIUM=true

# Khi true, high-risk tools (như edit_file) tự chạy mà không cần phê duyệt
# YOLO_AUTO_APPROVE_HIGH=true

# ── Sandbox ──────────────────────────────────────────────────
# Repo root (mặc định = thư mục hiện tại)
# YOLO_REPO_ROOT=.
